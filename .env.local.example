# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key — server-only, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic — used server-side only (API routes), never in the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Used to build the email confirmation redirect URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Product-discovery scraping (src/lib/scrapers). SUPABASE_SERVICE_ROLE_KEY
# above is required for this — the cache and error log tables have no RLS
# policies and are only reachable with that key.
SCRAPER_ENABLED=true
SCRAPER_TIMEOUT_MS=25000
SCRAPER_RATE_LIMIT_MS=3000
CACHE_TTL_HOURS=6
